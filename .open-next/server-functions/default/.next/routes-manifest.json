{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/widget/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ],
      "regex": "^/widget(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/invitacion/[token]",
      "regex": "^/invitacion/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/invitacion/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/profesional/[id]",
      "regex": "^/profesional/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/profesional/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/widget/[profesionalId]",
      "regex": "^/widget/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprofesionalId": "nxtPprofesionalId"
      },
      "namedRegex": "^/widget/(?<nxtPprofesionalId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/pagos/webhook",
      "regex": "^/api/pagos/webhook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/pagos/webhook(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/admin",
      "regex": "^/dashboard/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/admin(?:/)?$"
    },
    {
      "page": "/dashboard/clinica",
      "regex": "^/dashboard/clinica(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/clinica(?:/)?$"
    },
    {
      "page": "/dashboard/paciente",
      "regex": "^/dashboard/paciente(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/paciente(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/pago",
      "regex": "^/pago(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pago(?:/)?$"
    },
    {
      "page": "/pago-exitoso",
      "regex": "^/pago\\-exitoso(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pago\\-exitoso(?:/)?$"
    },
    {
      "page": "/pago-fallido",
      "regex": "^/pago\\-fallido(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pago\\-fallido(?:/)?$"
    },
    {
      "page": "/pago-pendiente",
      "regex": "^/pago\\-pendiente(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pago\\-pendiente(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}