{
  "name": "medisync-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build --webpack",
    "clean:cf": "node scripts/prepare-cloudflare-build.mjs",
    "build:cf": "npm run clean:cf && opennextjs-cloudflare build",
    "preview:cf": "npm run clean:cf && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "npm run clean:cf && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "purge:build-trash": "node scripts/purge-build-trash.mjs",
    "purge:build-trash:dry": "node scripts/purge-build-trash.mjs --dry-run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run typecheck && vitest run && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.5",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@opennextjs/cloudflare": "^1.19.5",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.90.0"
  }
}
